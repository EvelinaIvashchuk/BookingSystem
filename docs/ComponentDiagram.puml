@startuml CarRentalSystem_ComponentDiagram
skinparam componentFontSize 12
skinparam componentBackgroundColor #FAFAFA
skinparam componentBorderColor #555
skinparam interfaceBackgroundColor #E8F4FD
skinparam interfaceBorderColor #2980B9
skinparam arrowColor #333
skinparam packageBackgroundColor #FDFEFE
skinparam packageBorderColor #AAA
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #888
skinparam shadowing false
skinparam defaultTextAlignment center

title Car Rental System — Діаграма компонентів\n«Логічна структура системи та залежності між компонентами»

' ══════════════════════════════════════════════════════════════════
' ЗОВНІШНІ АКТОРИ
' ══════════════════════════════════════════════════════════════════

actor "Користувач\n(Browser)" as User
actor "Адміністратор\n(Browser)"  as Admin

' ══════════════════════════════════════════════════════════════════
' СИСТЕМА
' ══════════════════════════════════════════════════════════════════

package "CarRentalSystem (.NET 9 Web Application)" #F4F6F7 {

    ' ── PRESENTATION LAYER ──────────────────────────────────────
    package "Presentation Layer" #EBF5FB {

        component [RentalController]   as RentCtrl #ABEBC6
        component [AdminController]    as AdCtrl   #ABEBC6
        component [AccountController]  as AccCtrl  #ABEBC6
        component [CarController]      as CarCtrl  #ABEBC6
        component [HomeController]     as HmCtrl   #ABEBC6

        component [Razor Views\n(.cshtml)] as Views #D6EAF8

        package "ViewModels" #EBF5FB {
            component [RentalCreateViewModel] as RentVM
            component [LoginViewModel]        as LgVM
            component [RegisterViewModel]     as RgVM
        }

        package "Validators\n(FluentValidation)" #FEF5E7 {
            component [RentalCreateViewModelValidator] as RentVld
        }

        package "Helpers" #EAFAF1 {
            component [PaginatedList<T>] as PgList
        }
    }

    ' ── SERVICE LAYER ────────────────────────────────────────────
    package "Service Layer" #FEF9E7 {

        component [RentalService]    as RentSvc  #FAD7A0
        component [CarService]       as CarSvc   #FAD7A0
        component [UserService]      as UsrSvc   #FAD7A0
        component [MockEmailService] as EmailSvc #FAD7A0

        package "DTOs" #E8F8F5 {
            component [CreateRentalDto] as CrDto
            component [RentalDto]       as RentDto
        }

        package "Mappings\n(AutoMapper)" #F4ECF7 {
            component [RentalMappingProfile] as RentMap
        }

        package "Results" #EAFAF1 {
            component [ServiceResult<T>] as SR
        }

        ' Інтерфейси сервісів
        interface "IRentalService"   as IRentSvc
        interface "ICarService"      as ICarSvc
        interface "IUserService"     as IUsrSvc
        interface "IEmailService"    as IEmailSvc
    }

    ' ── DATA LAYER ───────────────────────────────────────────────
    package "Data Layer" #F5EEF8 {

        package "Unit of Work" #FDEBD0 {
            component [UnitOfWork] as UoW
            interface "IUnitOfWork" as IUoW
        }

        package "Repositories" #F5EEF8 {
            component [GenericRepository<T>]  as GnRepo
            component [RentalRepository]      as RentRepo
            component [CarRepository]         as CarRepo

            interface "IGenericRepository<T>"  as IGnRepo
            interface "IRentalRepository"      as IRentRepo
            interface "ICarRepository"         as ICarRepo
        }

        component [ApplicationDbContext\n(EF Core)] as DbCtx #D2B4DE
    }

    ' ── INFRASTRUCTURE ───────────────────────────────────────────
    package "Infrastructure" #FDFEFE {

        package "Identity" #F2F3F4 {
            component [ASP.NET Core Identity\n(UserManager, SignInManager)] as IdentitySvc
            component [ApplicationUser]  as AppUser
            component [DbSeeder]         as Seeder
        }

        package "Logging" #F2F3F4 {
            component [Serilog\n(Console + File)] as Serilog
        }

        package "Configuration" #F2F3F4 {
            component [appsettings.json\n(ConnectionString, Cookie)] as AppSettings
        }
    }
}

' ══════════════════════════════════════════════════════════════════
' ЗОВНІШНІ СИСТЕМИ
' ══════════════════════════════════════════════════════════════════

database "MySQL 8.0\n(Railway)" as MySQL #FADBD8

package "NuGet пакети «external»" #F2F3F4 {
    component [FluentValidation\n.AspNetCore 11.3] as FV    #D5D8DC
    component [AutoMapper\n12.0]                   as AM    #D5D8DC
    component [Pomelo EF Core\nMySQL 9.0]          as Pomelo #D5D8DC
    component [Serilog\n.AspNetCore]               as SerilogPkg #D5D8DC
}

' ══════════════════════════════════════════════════════════════════
' ЗВ'ЯЗКИ: Актори → Контролери
' ══════════════════════════════════════════════════════════════════

User  --> RentCtrl : HTTP GET/POST
User  --> CarCtrl  : HTTP GET
User  --> AccCtrl  : HTTP GET/POST
Admin --> AdCtrl   : HTTP GET/POST

' ══════════════════════════════════════════════════════════════════
' ЗВ'ЯЗКИ: Presentation Layer
' ══════════════════════════════════════════════════════════════════

RentCtrl  --> Views    : повертає View
RentCtrl  ..> IRentSvc : «uses»
RentCtrl  ..> ICarSvc  : «uses»
RentCtrl  ..> RentVld  : «validates»
RentCtrl  ..> RentMap  : «maps via IMapper»
RentCtrl  ..> RentVM   : «binds»

AdCtrl    ..> IRentSvc : «uses»
AdCtrl    ..> ICarSvc  : «uses»

CarCtrl   ..> ICarSvc  : «uses»
AccCtrl   ..> IdentitySvc : «uses»

RentVld   ..> FV       : «extends AbstractValidator»
RentMap   ..> AM       : «extends Profile»

' ══════════════════════════════════════════════════════════════════
' ЗВ'ЯЗКИ: Service Layer
' ══════════════════════════════════════════════════════════════════

RentSvc   ..|> IRentSvc   : «implements»
CarSvc    ..|> ICarSvc    : «implements»
UsrSvc    ..|> IUsrSvc    : «implements»
EmailSvc  ..|> IEmailSvc  : «implements»

RentSvc   ..> IUoW        : «uses»
RentSvc   ..> IEmailSvc   : «uses»
RentSvc   ..> CrDto       : «receives»
RentSvc   ..> SR          : «returns»

' ══════════════════════════════════════════════════════════════════
' ЗВ'ЯЗКИ: Data Layer
' ══════════════════════════════════════════════════════════════════

UoW       ..|> IUoW       : «implements»
UoW       --> IRentRepo   : «owns»
UoW       --> ICarRepo    : «owns»
UoW       --> DbCtx       : «CommitAsync»

RentRepo  --|> GnRepo     : «extends»
RentRepo  ..|> IRentRepo  : «implements»
CarRepo   --|> GnRepo     : «extends»
CarRepo   ..|> ICarRepo   : «implements»
GnRepo    ..|> IGnRepo    : «implements»
IRentRepo --|> IGnRepo    : «extends»
ICarRepo  --|> IGnRepo    : «extends»

GnRepo    --> DbCtx       : «uses»
DbCtx     --> MySQL       : «Pomelo EF Core»
DbCtx     ..> Pomelo      : «driver»

' ══════════════════════════════════════════════════════════════════
' ЗВ'ЯЗКИ: Infrastructure
' ══════════════════════════════════════════════════════════════════

IdentitySvc --> DbCtx       : «stores users/roles»
Seeder      --> IdentitySvc : «seeds roles + admin»
Serilog     ..> SerilogPkg  : «uses»
AppSettings --> DbCtx       : «ConnectionString»

' ══════════════════════════════════════════════════════════════════
' ПРИМІТКИ
' ══════════════════════════════════════════════════════════════════

note bottom of UoW
  Єдина точка CommitAsync().
  Координує RentalRepository
  та CarRepository.
end note

note right of RentVld
  Замінює DataAnnotations.
  Правила: дати, тривалість,
  кількість символів.
end note

note right of EmailSvc
  Mock-реалізація.
  Fire-and-forget через
  SafeSendEmailAsync.
end note

@enduml
