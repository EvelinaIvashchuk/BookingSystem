@startuml CarRentalSystem_UseCaseDiagram
skinparam actorStyle awesome
skinparam usecaseBackgroundColor #FAFAFA
skinparam usecaseBorderColor #555
skinparam usecaseFontSize 12
skinparam actorFontSize 13
skinparam arrowColor #333
skinparam packageBackgroundColor #FDFEFE
skinparam packageBorderColor #AAA
skinparam shadowing false
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #888

title Car Rental System — Use Case Діаграма\n«Функціональні вимоги: ролі та прецеденти»

' ══════════════════════════════════════════════════════════════════
' АКТОРИ
' ══════════════════════════════════════════════════════════════════

actor "Гість\n(Guest)" as Guest
actor "Користувач\n(User)" as User
actor "Адміністратор\n(Admin)" as Admin
actor "Email-сервіс\n(MockEmailService)" as EmailService

' Ієрархія акторів: User успадковує можливості Guest
Guest <|-- User   : «extends»
User  <|-- Admin  : «extends»

' ══════════════════════════════════════════════════════════════════
' СИСТЕМА
' ══════════════════════════════════════════════════════════════════

rectangle "Car Rental System" {

    ' ── Аутентифікація ──────────────────────────────────────────
    package "Аутентифікація" {
        usecase "Зареєструватися"         as UC_Register
        usecase "Увійти в систему"        as UC_Login
        usecase "Вийти з системи"         as UC_Logout
        usecase "Перевірити облікові\nдані (Identity)" as UC_ValidateCreds
    }

    ' ── Перегляд автомобілів ─────────────────────────────────────
    package "Перегляд автомобілів" {
        usecase "Переглянути список\nавтомобілів"         as UC_ListCars
        usecase "Переглянути деталі\nавтомобіля"          as UC_CarDetails
        usecase "Фільтрувати автомобілі\nза категорією"   as UC_FilterCars
    }

    ' ── Оренда (User) ───────────────────────────────────────────
    package "Управління орендою" {
        usecase "Створити оренду"              as UC_CreateRental
        usecase "Переглянути мої\nоренди"      as UC_MyRentals
        usecase "Переглянути деталі\nоренди"   as UC_RentalDetails
        usecase "Скасувати оренду"             as UC_CancelRental
        usecase "Перевірити доступність\nавтомобіля"      as UC_CheckAvailability
        usecase "Перевірити відсутність\nнакладань"        as UC_CheckOverlap
        usecase "Валідувати дані\nоренди"                  as UC_ValidateRental
        usecase "Розрахувати\nвартість оренди"             as UC_CalculatePrice
        usecase "Надіслати email-\nсповіщення"             as UC_SendEmail
    }

    ' ── Адмін-панель ─────────────────────────────────────────────
    package "Адміністрування" {
        usecase "Переглянути всі\nоренди"      as UC_AllRentals
        usecase "Підтвердити\nоренду"          as UC_ConfirmRental
        usecase "Відхилити\nоренду"            as UC_RejectRental
        usecase "Управляти\nавтомобілями"      as UC_ManageCars
        usecase "Управляти\nкористувачами"     as UC_ManageUsers
        usecase "Переглянути\nстатистику"      as UC_ViewStats
    }
}

' ══════════════════════════════════════════════════════════════════
' ЗВ'ЯЗКИ: Guest
' ══════════════════════════════════════════════════════════════════

Guest --> UC_Register
Guest --> UC_Login
Guest --> UC_ListCars
Guest --> UC_CarDetails

' ══════════════════════════════════════════════════════════════════
' ЗВ'ЯЗКИ: User
' ══════════════════════════════════════════════════════════════════

User --> UC_Logout
User --> UC_CreateRental
User --> UC_MyRentals
User --> UC_RentalDetails
User --> UC_CancelRental

' ══════════════════════════════════════════════════════════════════
' ЗВ'ЯЗКИ: Admin
' ══════════════════════════════════════════════════════════════════

Admin --> UC_AllRentals
Admin --> UC_ConfirmRental
Admin --> UC_RejectRental
Admin --> UC_ManageCars
Admin --> UC_ManageUsers
Admin --> UC_ViewStats

' ══════════════════════════════════════════════════════════════════
' ЗВ'ЯЗКИ: Email-сервіс (зовнішній актор)
' ══════════════════════════════════════════════════════════════════

UC_SendEmail --> EmailService

' ══════════════════════════════════════════════════════════════════
' ЗАЛЕЖНОСТІ МІЖ ПРЕЦЕДЕНТАМИ
' ══════════════════════════════════════════════════════════════════

' <<include>> — обов'язкова включена поведінка
UC_Login          ..> UC_ValidateCreds       : <<include>>
UC_CreateRental   ..> UC_ValidateRental      : <<include>>
UC_CreateRental   ..> UC_CheckAvailability   : <<include>>
UC_CreateRental   ..> UC_CalculatePrice      : <<include>>
UC_CheckAvailability ..> UC_CheckOverlap     : <<include>>
UC_CreateRental   ..> UC_SendEmail           : <<include>>
UC_CancelRental   ..> UC_SendEmail           : <<include>>
UC_ConfirmRental  ..> UC_SendEmail           : <<include>>
UC_RejectRental   ..> UC_SendEmail           : <<include>>

' <<extend>> — необов'язкова розширена поведінка
UC_FilterCars     ..> UC_ListCars            : <<extend>>
UC_RentalDetails  ..> UC_MyRentals           : <<extend>>
UC_CancelRental   ..> UC_MyRentals           : <<extend>>

' ══════════════════════════════════════════════════════════════════
' ПРИМІТКИ
' ══════════════════════════════════════════════════════════════════

note right of UC_ValidateRental
  FluentValidation:
  • PickupDate не в минулому
  • ReturnDate > PickupDate
  • Тривалість: 1 день – 30 днів
  • Не більше 60 днів наперед
  • Notes ≤ 500 символів
end note

note right of UC_CheckAvailability
  RentalService:
  • Автомобіль існує та Available
  • Активних оренд ≤ 3
  • Відсутність накладань по датах
end note

note right of UC_CalculatePrice
  RentalService:
  TotalPrice =
  (ReturnDate - PickupDate).Days
  × car.PricePerDay
end note

note bottom of UC_ConfirmRental
  Тільки для Pending-оренд.
  Адмін може додати AdminNote.
end note

@enduml
