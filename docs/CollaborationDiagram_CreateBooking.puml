@startuml CarRentalSystem_CollaborationDiagram
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classBackgroundColor #FAFAFA
skinparam classBorderColor #555
skinparam arrowColor #333
skinparam arrowFontSize 11
skinparam shadowing false
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #888
skinparam packageBackgroundColor #FDFEFE
skinparam packageBorderColor #AAA

title Car Rental System — Діаграма кооперації\n«Створення оренди: об'єкти та пронумеровані повідомлення»

' ══════════════════════════════════════════════════════════════════
' ОБ'ЄКТИ (екземпляри класів)
' ══════════════════════════════════════════════════════════════════

object ":Користувач" as User #EBF5FB {
    userId : string
}

object ":RentalController" as Ctrl #EAF7EA {
    mapper    : IMapper
    validator : IValidator<RentalCreateViewModel>
}

object ":RentalCreateViewModel" as VM #EBF5FB {
    CarId      : int
    PickupDate : DateTime
    ReturnDate : DateTime
    Notes      : string?
}

object ":RentalCreateViewModelValidator" as Vld #FEF5E7 {
    MinDurationDays = 1
    MaxDurationDays = 30
    MaxAdvanceDays  = 60
}

object ":RentalMappingProfile\n(IMapper)" as Mpr #F4ECF7 {
    RentalCreateViewModel\n→ CreateRentalDto
}

object ":CreateRentalDto" as Dto #E8F8F5 {
    CarId      : int
    PickupDate : DateTime
    ReturnDate : DateTime
    Notes      : string?
}

object ":RentalService" as Svc #FEF9E7 {
    MaxActiveRentals = 3
}

object ":UnitOfWork" as UoW #FDEBD0 {
    Rentals : IRentalRepository
    Cars    : ICarRepository
}

object ":CarRepository" as CarRepo #F5EEF8 {
}

object ":RentalRepository" as RentRepo #F5EEF8 {
}

object ":ApplicationDbContext" as DB #FDEDEC {
    Cars    : DbSet<Car>
    Rentals : DbSet<Rental>
}

object ":Rental" as RentEntity #FDEDEC {
    Status    = Pending
    TotalPrice = calculated
    CreatedAt = UtcNow
}

object ":MockEmailService" as Email #EAFAF1 {
}

' ══════════════════════════════════════════════════════════════════
' ПОВІДОМЛЕННЯ З НУМЕРАЦІЄЮ
' (Кооперативна діаграма: нумерація відображає порядок викликів)
' ══════════════════════════════════════════════════════════════════

' 1. Користувач надсилає форму
User --> Ctrl : 1: POST Create(vm)

' 2. Контролер прив'язує ViewModel
Ctrl --> VM : 2: bind(HttpRequest)

' 3. FluentValidation
Ctrl --> Vld : 3: ValidateAsync(vm)
Vld --> VM   : 3.1: перевірити поля

note on link
  3.1a: [fail] → повернути View
  з помилками до Користувача
end note

' 4. AutoMapper
Ctrl --> Mpr : 4: Map<CreateRentalDto>(vm)
Mpr  --> Dto : 4.1: new CreateRentalDto(...)

' 5. Виклик сервісу
Ctrl --> Svc : 5: CreateRentalAsync(userId, dto)

' 6. Статична перевірка дат
Svc --> Svc : 6: ValidateDates(pickupDate, returnDate)

note on link
  6a: [fail] → ServiceResult.Fail
end note

' 7. Перевірка автомобіля
Svc  --> UoW     : 7: uow.Cars.GetWithCategoryAsync(id)
UoW  --> CarRepo : 7.1: GetWithCategoryAsync(id)
CarRepo --> DB   : 7.2: SELECT Car + Category
DB --> CarRepo   : 7.3: Car entity

note on link
  7a: [null] → Fail "does not exist"
  7b: [!Available] → Fail "not available"
end note

' 8. Ліміт активних оренд
Svc  --> UoW      : 8: uow.Rentals.GetActiveRentalCountAsync(userId)
UoW  --> RentRepo : 8.1: GetActiveRentalCountAsync(userId)
RentRepo --> DB   : 8.2: SELECT COUNT(*) Pending/Confirmed
DB --> RentRepo   : 8.3: int count

note on link
  8a: [count >= 3] → Fail "max rentals"
end note

' 9. Перевірка overlap
Svc  --> UoW      : 9: uow.Rentals.HasOverlapAsync(id, pickupDate, returnDate)
UoW  --> RentRepo : 9.1: HasOverlapAsync(...)
RentRepo --> DB   : 9.2: SELECT EXISTS overlap by dates
DB --> RentRepo   : 9.3: bool hasOverlap

note on link
  9a: [true] → Fail "already booked"
end note

' 10. Розрахунок вартості
Svc --> Svc : 10: TotalPrice =\n(ReturnDate - PickupDate).Days\n× car.PricePerDay

' 11. Створення сутності
Svc --> RentEntity : 11: new Rental { Status=Pending,\nTotalPrice=totalPrice }

' 12. Збереження
Svc  --> UoW      : 12: uow.Rentals.AddAsync(rental)
UoW  --> RentRepo : 12.1: AddAsync(rental)
RentRepo --> DB   : 12.2: context.Add(rental)
Svc  --> UoW      : 13: uow.CommitAsync()
UoW  --> DB       : 13.1: SaveChangesAsync()

' 14. Завантаження з деталями
Svc  --> UoW      : 14: uow.Rentals.GetWithDetailsAsync(id)
UoW  --> RentRepo : 14.1: GetWithDetailsAsync(id)
RentRepo --> DB   : 14.2: SELECT + Include User, Car
DB --> RentRepo   : 14.3: Rental (повний)

' 15. Email (fire-and-forget)
Svc --> Email : 15: SendRentalCreatedAsync(...)\n«fire-and-forget»

' 16. Відповідь
Svc  --> Ctrl : 16: ServiceResult<Rental>.Ok(created)
Ctrl --> User : 17: Redirect → MyRentals\n+ TempData["Success"]

' ══════════════════════════════════════════════════════════════════
' ЛЕГЕНДА
' ══════════════════════════════════════════════════════════════════

legend right
  |= Позначення |= Значення |
  | 1, 2, 3 ... | Порядок повідомлень |
  | 3.1, 7.2 ... | Вкладений виклик |
  | [fail] | Умовна гілка відмови |
  | «fire-and-forget» | Асинхронний виклик без очікування |
endlegend

@enduml
