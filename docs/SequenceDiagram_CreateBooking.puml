@startuml CarRentalSystem_SequenceDiagram
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantFontSize 12
skinparam sequenceLifeLineBorderColor #555
skinparam sequenceArrowColor #333
skinparam sequenceParticipantBackgroundColor #FAFAFA
skinparam sequenceParticipantBorderColor #555
skinparam sequenceGroupBackgroundColor #FFFDE7
skinparam sequenceGroupBorderColor #E67E22
skinparam sequenceBoxBackgroundColor #F4F6F7
skinparam sequenceBoxBorderColor #AAA
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #888
skinparam shadowing false
skinparam responseMessageBelowArrow true

title Car Rental System — Діаграма послідовності\n«Створення оренди: POST /Rental/Create»

' ══════════════════════════════════════════════════════════════════
' УЧАСНИКИ
' ══════════════════════════════════════════════════════════════════

actor       "Користувач"              as User
participant "RentalController"        as Ctrl    #EBF5FB
participant "IValidator\n<RentalCreateViewModel>" as Validator #FEF5E7
participant "IMapper\n(AutoMapper)"   as Mapper  #F4ECF7
participant "RentalService"           as Svc     #FEF9E7
participant "UnitOfWork"              as UoW     #FDEBD0
participant "CarRepository"           as CarRepo #F5EEF8
participant "RentalRepository"        as RentRepo #F5EEF8
participant "ApplicationDbContext"    as DB      #FDEDEC
participant "MockEmailService"        as Email   #EAFAF1

' ══════════════════════════════════════════════════════════════════
' 1. HTTP-запит
' ══════════════════════════════════════════════════════════════════

User -> Ctrl : POST /Rental/Create\n(RentalCreateViewModel vm)
activate Ctrl

' ══════════════════════════════════════════════════════════════════
' 2. FluentValidation
' ══════════════════════════════════════════════════════════════════

group FluentValidation [UI-рівень]
    Ctrl -> Validator : ValidateAsync(vm)
    activate Validator
    Validator --> Ctrl : ValidationResult
    deactivate Validator

    alt Валідація не пройшла
        Ctrl -> Ctrl : AddToModelState(errors)\nRepopulateDisplayFields(vm)
        Ctrl --> User : View(vm) з помилками
    end
end

' ══════════════════════════════════════════════════════════════════
' 3. AutoMapper: ViewModel → DTO
' ══════════════════════════════════════════════════════════════════

group AutoMapper [Перетворення типів]
    Ctrl -> Mapper : Map<CreateRentalDto>(vm)
    activate Mapper
    Mapper --> Ctrl : CreateRentalDto dto
    deactivate Mapper
end

' ══════════════════════════════════════════════════════════════════
' 4. Виклик сервісу
' ══════════════════════════════════════════════════════════════════

Ctrl -> Svc : CreateRentalAsync(userId, dto)
activate Svc

' ── 4.1 Статична перевірка дат ───────────────────────────────────
group Бізнес-валідація [RentalService]
    Svc -> Svc : ValidateDates(dto.PickupDate, dto.ReturnDate)
    note right of Svc
      • PickupDate не в минулому
      • ReturnDate > PickupDate
      • Тривалість: 1 день – 30 днів
      • Не далі 60 днів наперед
    end note

    alt Дати невалідні
        Svc --> Ctrl : ServiceResult.Fail("...")
        Ctrl --> User : View з помилкою
    end
end

' ── 4.2 Перевірка автомобіля ─────────────────────────────────────
group Перевірка автомобіля [IUnitOfWork → CarRepository]
    Svc -> UoW : uow.Cars.GetWithCategoryAsync(dto.CarId)
    activate UoW
    UoW -> CarRepo : GetWithCategoryAsync(id)
    activate CarRepo
    CarRepo -> DB : SELECT Car + Category\nWHERE id = dto.CarId
    activate DB
    DB --> CarRepo : Car entity
    deactivate DB
    CarRepo --> UoW : Car
    deactivate CarRepo
    UoW --> Svc : Car
    deactivate UoW

    alt Автомобіль не знайдено
        Svc --> Ctrl : ServiceResult.Fail("car does not exist")
        Ctrl --> User : View з помилкою
    else Автомобіль не Available
        Svc --> Ctrl : ServiceResult.Fail("car is not available")
        Ctrl --> User : View з помилкою
    end
end

' ── 4.3 Ліміт активних оренд ─────────────────────────────────────
group Ліміт оренд [IUnitOfWork → RentalRepository]
    Svc -> UoW : uow.Rentals.GetActiveRentalCountAsync(userId)
    activate UoW
    UoW -> RentRepo : GetActiveRentalCountAsync(userId)
    activate RentRepo
    RentRepo -> DB : SELECT COUNT(*) FROM Rentals\nWHERE userId = ... AND\nstatus IN (Pending, Confirmed)
    activate DB
    DB --> RentRepo : int count
    deactivate DB
    RentRepo --> UoW : int count
    deactivate RentRepo
    UoW --> Svc : int count
    deactivate UoW

    alt count >= 3
        Svc --> Ctrl : ServiceResult.Fail("max 3 active rentals")
        Ctrl --> User : View з помилкою
    end
end

' ── 4.4 Перевірка накладань ───────────────────────────────────────
group Перевірка overlap [IUnitOfWork → RentalRepository]
    Svc -> UoW : uow.Rentals.HasOverlapAsync\n(carId, pickupDate, returnDate)
    activate UoW
    UoW -> RentRepo : HasOverlapAsync(carId, pickupDate, returnDate)
    activate RentRepo
    RentRepo -> DB : SELECT EXISTS (\n  SELECT 1 FROM Rentals\n  WHERE carId = ...\n  AND PickupDate < returnDate\n  AND ReturnDate > pickupDate\n  AND status IN (Pending, Confirmed)\n)
    activate DB
    DB --> RentRepo : bool hasOverlap
    deactivate DB
    RentRepo --> UoW : bool hasOverlap
    deactivate RentRepo
    UoW --> Svc : bool hasOverlap
    deactivate UoW

    alt hasOverlap == true
        Svc --> Ctrl : ServiceResult.Fail("already booked")
        Ctrl --> User : View з помилкою
    end
end

' ── 4.5 Розрахунок вартості та збереження ────────────────────────
group Збереження [IUnitOfWork.CommitAsync]
    Svc -> Svc : TotalPrice =\n(ReturnDate - PickupDate).Days\n× car.PricePerDay

    Svc -> UoW : uow.Rentals.AddAsync(rental)
    activate UoW
    UoW -> RentRepo : AddAsync(rental)
    activate RentRepo
    RentRepo -> DB : context.Rentals.AddAsync(rental)
    activate DB
    DB --> RentRepo : —
    deactivate DB
    RentRepo --> UoW : —
    deactivate RentRepo

    UoW -> DB : SaveChangesAsync()\n[CommitAsync]
    activate DB
    DB --> UoW : int (кількість змін)
    deactivate DB
    UoW --> Svc : —
    deactivate UoW
end

' ── 4.6 Завантаження деталей ─────────────────────────────────────
Svc -> UoW : uow.Rentals.GetWithDetailsAsync(rental.Id)
activate UoW
UoW -> RentRepo : GetWithDetailsAsync(id)
activate RentRepo
RentRepo -> DB : SELECT Rental + User + Car\nWHERE id = rental.Id
activate DB
DB --> RentRepo : Rental (з навігаційними властивостями)
deactivate DB
RentRepo --> UoW : Rental
deactivate RentRepo
UoW --> Svc : Rental created
deactivate UoW

' ── 4.7 Email (fire-and-forget) ──────────────────────────────────
group Email сповіщення [fire-and-forget]
    Svc ->> Email : SendRentalCreatedAsync\n(email, name, car, pickupDate, returnDate, totalPrice)
    activate Email
    note right of Email
      «fire-and-forget»:
      _ = SafeSendEmailAsync(...)
      Помилка лише логується.
    end note
    Email -->> Svc : (async, не блокує)
    deactivate Email
end

Svc --> Ctrl : ServiceResult<Rental>.Ok(created)
deactivate Svc

' ══════════════════════════════════════════════════════════════════
' 5. Відповідь користувачу
' ══════════════════════════════════════════════════════════════════

Ctrl -> Ctrl : TempData["Success"] = "..."
Ctrl --> User : RedirectToAction(MyRentals)
deactivate Ctrl

@enduml
