@startuml CarRentalSystem_ActivityDiagram
skinparam activityFontSize 12
skinparam activityBorderColor #555
skinparam activityBackgroundColor #FAFAFA
skinparam activityArrowColor #333
skinparam activityDiamondBackgroundColor #FEF9E7
skinparam activityDiamondBorderColor #E67E22
skinparam shadowing false
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #888
skinparam swimlaneBackgroundColor #FDFEFE
skinparam swimlaneBorderColor #AAA

title Car Rental System — Діаграма активності\n«Процес створення та обробки оренди автомобіля»

|#EBF5FB| Користувач (User) |
|#FEF9E7| RentalController |
|#E8F8F5| RentalService |
|#F5EEF8| База даних (DB) |
|#FDEBD0| Адміністратор (Admin) |

' ══════════════════════════════════════════════════════════════════
' ПОЧАТОК
' ══════════════════════════════════════════════════════════════════

|Користувач (User)|
start

:Відкрити сторінку автомобіля;
:Натиснути «Орендувати»;

|RentalController|
:GET /Rental/Create?carId={id};

:Завантажити автомобіль через\nICarService;

|База даних (DB)|
:SELECT Car WHERE id = {id};
:Повернути Car;

|RentalController|

if (Автомобіль знайдено?) then (ні)
    :Повернути 404 NotFound;
    stop
endif

if (Car.Status == Available?) then (ні)
    :TempData["Error"]\n→ Redirect до деталей автомобіля;
    stop
endif

:Відобразити форму оренди\n(RentalCreateViewModel);

' ══════════════════════════════════════════════════════════════════
' ЗАПОВНЕННЯ ФОРМИ
' ══════════════════════════════════════════════════════════════════

|Користувач (User)|
:Заповнити форму:\n- PickupDate\n- ReturnDate\n- Notes (опційно);
:Натиснути «Підтвердити»;

' ══════════════════════════════════════════════════════════════════
' ВАЛІДАЦІЯ (FluentValidation)
' ══════════════════════════════════════════════════════════════════

|RentalController|
:POST /Rental/Create;

note right
  IValidator<RentalCreateViewModel>
  (FluentValidation)
end note

:Виконати validator.ValidateAsync(vm);

if (Валідація пройшла?) then (ні)
    :Додати помилки до ModelState\n(AddToModelState);
    :RepopulateDisplayFields(vm);
    :Повернути View з помилками;
    |Користувач (User)|
    :Виправити форму;
    detach
endif

' ══════════════════════════════════════════════════════════════════
' МАППІНГ (AutoMapper)
' ══════════════════════════════════════════════════════════════════

|RentalController|

note right
  IMapper / RentalMappingProfile
  (AutoMapper)
end note

:mapper.Map<CreateRentalDto>(vm)\nViewModel → DTO;

:rentalService.CreateRentalAsync\n(userId, dto);

' ══════════════════════════════════════════════════════════════════
' БІЗНЕС-ЛОГІКА (RentalService)
' ══════════════════════════════════════════════════════════════════

|RentalService|

:ValidateDates(pickupDate, returnDate)\n[статична перевірка дат];

if (Дати коректні?) then (ні)
    :Повернути ServiceResult.Fail;
    |RentalController|
    :ModelState.AddModelError\n→ View з помилкою;
    stop
endif

|База даних (DB)|
:SELECT Car + Category\nWHERE id = dto.CarId;
:Повернути Car;

|RentalService|

if (Автомобіль Available?) then (ні)
    :Повернути ServiceResult.Fail\n«car is not available»;
    stop
endif

|База даних (DB)|
:SELECT COUNT(Rentals)\nWHERE userId = ... AND status IN\n(Pending, Confirmed);
:Повернути activeCount;

|RentalService|

if (activeCount < 3?) then (ні)
    :Повернути ServiceResult.Fail\n«you already have 3 active rentals»;
    stop
endif

|База даних (DB)|
:SELECT EXISTS Rentals\nWHERE carId = ...\nAND overlap(pickupDate, returnDate);
:Повернути hasOverlap;

|RentalService|

if (Накладань немає?) then (ні)
    :Повернути ServiceResult.Fail\n«car is already booked for these dates»;
    stop
endif

' ══════════════════════════════════════════════════════════════════
' РОЗРАХУНОК ВАРТОСТІ ТА ЗБЕРЕЖЕННЯ (UnitOfWork)
' ══════════════════════════════════════════════════════════════════

:Розрахувати TotalPrice\n= (ReturnDate - PickupDate).Days\n× car.PricePerDay;

:Створити Rental\n{Status = Pending, CreatedAt = UtcNow,\nTotalPrice = totalPrice};

|База даних (DB)|
:uow.Rentals.AddAsync(rental)\nuow.CommitAsync()\n→ INSERT INTO Rentals;
:Повернути rental.Id;

|RentalService|
:GetWithDetailsAsync(rental.Id)\n(eager load User + Car);

|База даних (DB)|
:SELECT Rental + User + Car\nWHERE id = rental.Id;
:Повернути повний об'єкт;

' ══════════════════════════════════════════════════════════════════
' EMAIL (fire-and-forget)
' ══════════════════════════════════════════════════════════════════

|RentalService|

fork
    :SafeSendEmailAsync\n→ SendRentalCreatedAsync\n(email, name, car, pickupDate, returnDate, totalPrice);
    note right
      Fire-and-forget.
      Помилка лише логується,
      не перериває потік.
    end note
fork again
    :Повернути ServiceResult.Ok(rental);
end fork

' ══════════════════════════════════════════════════════════════════
' ВІДПОВІДЬ КОНТРОЛЕРА
' ══════════════════════════════════════════════════════════════════

|RentalController|
:TempData["Success"]\n→ RedirectToAction(MyRentals);

|Користувач (User)|
:Переглянути список\nсвоїх оренд;

' ══════════════════════════════════════════════════════════════════
' АДМІН-ОБРОБКА
' ══════════════════════════════════════════════════════════════════

|Адміністратор (Admin)|
:Відкрити панель адміністрування\n→ Переглянути Pending оренди;

if (Рішення адміністратора?) then (Підтвердити)
    :POST /Admin/Rental/Confirm/{id}\n(з опційним AdminNote);
    |RentalService|
    :rental.Status = Confirmed\nuow.CommitAsync();
    :SafeSendEmailAsync\n→ SendRentalConfirmedAsync;
    |Адміністратор (Admin)|
    :Оренду підтверджено;
else (Відхилити)
    :POST /Admin/Rental/Reject/{id}\n(з обов'язковим AdminNote);
    |RentalService|
    :rental.Status = Rejected\nuow.CommitAsync();
    :SafeSendEmailAsync\n→ SendRentalRejectedAsync;
    |Адміністратор (Admin)|
    :Оренду відхилено;
endif

stop

@enduml
