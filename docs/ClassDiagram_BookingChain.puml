title Car Rental System — Діаграма класів\n«Ланцюжок: RentalController → RentalService → UnitOfWork → RentalRepository → GenericRepository → Rental»

' ══════════════════════════════════════════════════════════════════
' PACKAGE: ViewModels
' ══════════════════════════════════════════════════════════════════
package "ViewModels" #EBF5FB {

    class RentalCreateViewModel {
        + CarId        : int
        + CarName      : string
        + Location     : string
        + PricePerDay  : decimal
        + CategoryName : string
        .. Валідується через FluentValidation ..
        + PickupDate : DateTime?
        + ReturnDate : DateTime?
        + Notes      : string?
    }
}

' ══════════════════════════════════════════════════════════════════
' PACKAGE: Validators (FluentValidation)
' ══════════════════════════════════════════════════════════════════
package "Validators" #FEF5E7 {

    class RentalCreateViewModelValidator {
        - MinDurationDays  : int = 1   «const»
        - MaxDurationDays  : int = 30  «const»
        - MaxAdvanceDays   : int = 60  «const»
        --
        + RentalCreateViewModelValidator()
        .. Правила ..
        # PickupDate >= UtcNow.Date
        # ReturnDate > PickupDate
        # Duration: 1 день – 30 днів
        # Не більше 60 днів наперед
        # Notes.Length ≤ 500
    }

    note right of RentalCreateViewModelValidator
      Реалізує AbstractValidator<T>.
      Замінює DataAnnotations —
      правила зосереджені в одному
      місці, легко тестуються.
    end note
}

