        + CarName     : string
        + PickupDate  : DateTime
        + ReturnDate  : DateTime
        + TotalPrice  : decimal
        + Notes       : string?
        + Status      : RentalStatus
        + CreatedAt   : DateTime
    }

    note bottom of CreateRentalDto
      Відокремлює сервісний шар
      від MVC-специфічного ViewModel.
      Controller → Service.
    end note
}

' ══════════════════════════════════════════════════════════════════
' PACKAGE: AutoMapper
' ══════════════════════════════════════════════════════════════════
package "Mappings" #F4ECF7 {

    class RentalMappingProfile {
        + RentalMappingProfile()
        .. Маппінги ..
        # RentalCreateViewModel → CreateRentalDto
        # Rental → RentalDto
    }

    note right of RentalMappingProfile
      Успадковує Profile (AutoMapper).
      Реєструється через
      AddAutoMapper() в Program.cs.
    end note
}

' ══════════════════════════════════════════════════════════════════
' PACKAGE: Controllers
' ══════════════════════════════════════════════════════════════════
package "Controllers" #EAF7EA {

    class RentalController {
        - _rentalService : IRentalService
        - _carService    : ICarService
        - _mapper        : IMapper
        - _validator     : IValidator<RentalCreateViewModel>
        --
        + Create(carId: int) : Task<IActionResult>
        + Create(vm: RentalCreateViewModel) : Task<IActionResult>
        + MyRentals(page: int) : Task<IActionResult>
        + Details(id: int) : Task<IActionResult>
        + Cancel(id: int) : Task<IActionResult>
        - RepopulateDisplayFields(vm) : Task
    }

    note right of RentalController
      «Authorize» — тільки
      автентифіковані користувачі.
      1. Валідує через IValidator
      2. Маппить ViewModel→DTO
         через IMapper
      3. Передає DTO в IRentalService
    end note
}

' ══════════════════════════════════════════════════════════════════
' PACKAGE: Services
' ══════════════════════════════════════════════════════════════════
package "Services" #FEF9E7 {

    interface IRentalService <<interface>> {
        + CreateRentalAsync(userId: string, dto: CreateRentalDto) : Task<ServiceResult<Rental>>
        + CancelRentalAsync(rentalId: int, userId: string) : Task<ServiceResult>
        + ConfirmRentalAsync(rentalId: int, adminNote: string?) : Task<ServiceResult>
        + RejectRentalAsync(rentalId: int, adminNote: string) : Task<ServiceResult>
        + GetUserRentalsAsync(userId: string) : Task<IEnumerable<Rental>>
        + GetAllRentalsAsync() : Task<IEnumerable<Rental>>
        + GetRentalByIdAsync(id: int) : Task<Rental?>
    }

    class RentalService {
        - MaxActiveRentalsPerUser : int = 3   «const»
        - MinDurationDays         : int = 1   «const»
        - MaxDurationDays         : int = 30  «const»
        - MaxAdvanceBookingDays   : int = 60  «const»
        --
        - _uow          : IUnitOfWork
        - _emailService : IEmailService
        - _logger       : ILogger<RentalService>
        --
        + CreateRentalAsync(userId, dto) : Task<ServiceResult<Rental>>
        + CancelRentalAsync(rentalId, userId) : Task<ServiceResult>
        + ConfirmRentalAsync(rentalId, adminNote) : Task<ServiceResult>
        + RejectRentalAsync(rentalId, adminNote) : Task<ServiceResult>
        + GetUserRentalsAsync(userId) : Task<IEnumerable<Rental>>
        + GetAllRentalsAsync() : Task<IEnumerable<Rental>>
        + GetRentalByIdAsync(id) : Task<Rental?>
        - ValidateDates(pickupDate, returnDate) : ServiceResult
        - SafeSendEmailAsync(action: Func<Task>) : Task
    }

    note right of RentalService
      Бізнес-правила:
      • PickupDate у майбутньому
      • ReturnDate > PickupDate
      • Тривалість: 1 день – 30 днів
      • Не більше 60 днів наперед
      • Автомобіль = Available
      • Макс. 3 активних оренди
      • Відсутність накладань (overlap)
      • TotalPrice = днів × PricePerDay
      Зберігає через uow.CommitAsync()
    end note

    class ServiceResult<T> {
        + IsSuccess : bool
        + Value : T?
        + Error : string?
        --
        + {static} Ok(value: T) : ServiceResult<T>
        + {static} Fail(error: string) : ServiceResult<T>
    }

    class ServiceResult {
        + IsSuccess : bool
        + Error : string?
        --
        + {static} Ok() : ServiceResult
        + {static} Fail(error: string) : ServiceResult
    }

    interface IEmailService <<interface>> {
        + SendRentalCreatedAsync(email, name, car, pickupDate, returnDate, totalPrice) : Task
        + SendRentalCancelledAsync(email, name, car, pickupDate, returnDate) : Task
        + SendRentalConfirmedAsync(email, name, car, pickupDate, returnDate) : Task
        + SendRentalRejectedAsync(email, name, car, note) : Task
    }

    class MockEmailService {
        - _logger : ILogger<MockEmailService>
        --
        + SendRentalCreatedAsync(...) : Task
        + SendRentalCancelledAsync(...) : Task
        + SendRentalConfirmedAsync(...) : Task
        + SendRentalRejectedAsync(...) : Task
    }
}

' ══════════════════════════════════════════════════════════════════
' PACKAGE: Unit of Work
' ══════════════════════════════════════════════════════════════════
package "Data / Unit of Work" #FDEBD0 {

    interface IUnitOfWork <<interface>> {
        + Rentals : IRentalRepository
        + Cars    : ICarRepository
        --
        + CommitAsync(ct: CancellationToken) : Task<int>
    }

    class UnitOfWork {
        - _db : ApplicationDbContext
        --
        + Rentals : IRentalRepository
        + Cars    : ICarRepository
        --
        + UnitOfWork(db, rentals, cars)
        + CommitAsync(ct) : Task<int>
        + DisposeAsync() : ValueTask
    }

    note right of IUnitOfWork
      Координує репозиторії.
      Єдиний CommitAsync() —
      атомарне збереження.
      Вирішує проблему часткового
      збереження при роботі з
      кількома репозиторіями.
    end note
}

' ══════════════════════════════════════════════════════════════════
' PACKAGE: Repositories
' ══════════════════════════════════════════════════════════════════
package "Data / Repositories" #F5EEF8 {

    interface IGenericRepository<T> <<interface>> {
        + GetByIdAsync(id: int) : Task<T?>
        + GetAllAsync() : Task<IReadOnlyList<T>>
        + FindAsync(predicate: Expression<Func<T,bool>>) : Task<IReadOnlyList<T>>
        + AnyAsync(predicate: Expression<Func<T,bool>>) : Task<bool>
        + AddAsync(entity: T) : Task
        + Update(entity: T) : void
        + Delete(entity: T) : void
        + SaveChangesAsync() : Task
    }

    interface IRentalRepository <<interface>> {
        + GetUserRentalsAsync(userId: string) : Task<IEnumerable<Rental>>
        + GetAllWithDetailsAsync() : Task<IEnumerable<Rental>>
        + GetWithDetailsAsync(id: int) : Task<Rental?>
        + HasOverlapAsync(carId, pickupDate, returnDate, excludeRentalId?) : Task<bool>
        + GetActiveRentalCountAsync(userId: string) : Task<int>
    }

    interface ICarRepository <<interface>> {
        + GetAllWithCategoryAsync() : Task<IEnumerable<Car>>
        + GetAvailableWithCategoryAsync() : Task<IReadOnlyList<Car>>
        + GetWithCategoryAsync(id: int) : Task<Car?>
        + IsRentableAsync(id: int) : Task<bool>
    }

    class GenericRepository<T> {
        # _db : ApplicationDbContext
        --
        + GenericRepository(db: ApplicationDbContext)
        --
        + GetByIdAsync(id) : Task<T?>
        + GetAllAsync() : Task<IReadOnlyList<T>>
        + FindAsync(predicate) : Task<IReadOnlyList<T>>
        + AnyAsync(predicate) : Task<bool>
        + AddAsync(entity) : Task
        + Update(entity) : void
        + Delete(entity) : void
        + SaveChangesAsync() : Task
    }

    class RentalRepository {
        + RentalRepository(db: ApplicationDbContext)
        --
        + GetUserRentalsAsync(userId) : Task<IEnumerable<Rental>>
        + GetAllWithDetailsAsync() : Task<IEnumerable<Rental>>
        + GetWithDetailsAsync(id) : Task<Rental?>
        + HasOverlapAsync(carId, pickupDate, returnDate, excludeRentalId?) : Task<bool>
        + GetActiveRentalCountAsync(userId) : Task<int>
    }

    class CarRepository {
        + CarRepository(db: ApplicationDbContext)
        --
        + GetAllWithCategoryAsync() : Task<IEnumerable<Car>>
        + GetAvailableWithCategoryAsync() : Task<IReadOnlyList<Car>>
        + GetWithCategoryAsync(id) : Task<Car?>
        + IsRentableAsync(id) : Task<bool>
    }

    class ApplicationDbContext {
        + Cars       : DbSet<Car>
        + Rentals    : DbSet<Rental>
        + Categories : DbSet<Category>
        + Payments   : DbSet<Payment>
        --
        + ApplicationDbContext(options)
        # OnModelCreating(builder) : void
    }
}

' ══════════════════════════════════════════════════════════════════
' PACKAGE: Entities
' ══════════════════════════════════════════════════════════════════
package "Models / Entities" #FDEDEC {

    class Rental {
        + Id          : int
        + UserId      : string      «FK»
        + CarId       : int         «FK»
        + PickupDate  : DateTime
        + ReturnDate  : DateTime
        + TotalPrice  : decimal
        + Notes       : string?
        + Status      : RentalStatus
        + CreatedAt   : DateTime
        + CancelledAt : DateTime?
        + AdminNote   : string?
        --
        + User    : ApplicationUser  «navigation»
        + Car     : Car              «navigation»
        + Payment : Payment?         «navigation»
        --
        + DurationDays             : double  «computed»
        + CanBeCancelledByUser     : bool    «computed»
    }

    class Car {
        + Id           : int
        + Brand        : string
        + Model        : string
        + Year         : int
        + LicensePlate : string      «[Unique]»
        + FuelType     : FuelType
        + Transmission : Transmission
        + Seats        : int
        + PricePerDay  : decimal
        + Description  : string?
        + Location     : string
        + Status       : CarStatus
        + ImageUrl     : string?
        + CategoryId   : int         «FK»
        --
        + Category : Category              «navigation»
        + Rentals  : ICollection<Rental>   «navigation»
        --
        + FullName : string  «computed (Brand Model (Year))»
    }

    class Payment {
        + Id                   : int
        + RentalId             : int      «FK (one-to-one)»
        + Amount               : decimal
        + Status               : PaymentStatus
        + PaidAt               : DateTime?
        + TransactionReference : string?
        + CreatedAt            : DateTime
        --
        + Rental : Rental  «navigation»
    }

    class ApplicationUser {
        + FirstName : string
        + LastName  : string
        + IsActive  : bool
        + CreatedAt : DateTime
        --
        + Rentals : ICollection<Rental>  «navigation»
        --
        + FullName : string  «computed»
    }

    class Category {
        + Id          : int
        + Name        : string  «[Unique]»
        + Description : string?
        --
        + Cars : ICollection<Car>  «navigation»
    }

    enum RentalStatus <<enumeration>> {
        Pending
        Confirmed
        Cancelled
        Rejected
    }

    enum CarStatus <<enumeration>> {
        Available
        Rented
        UnderMaintenance
    }

    enum FuelType <<enumeration>> {
        Petrol
        Diesel
        Electric
        Hybrid
    }

    enum Transmission <<enumeration>> {
        Manual
        Automatic
    }

    enum PaymentStatus <<enumeration>> {
        Unpaid
        Paid
        Refunded
    }
}

' ══════════════════════════════════════════════════════════════════
' PACKAGE: ASP.NET Core Identity (external)
' ══════════════════════════════════════════════════════════════════
package "ASP.NET Core Identity «external»" #F2F3F4 {

    class IdentityUser<TKey> <<abstract>> {
        + Id           : TKey
        + UserName     : string?
        + Email        : string?
        + PasswordHash : string?
        + EmailConfirmed : bool
    }

    class IdentityDbContext<TUser> <<abstract>> {
        + Users : DbSet<TUser>
        + Roles : DbSet<IdentityRole>
    }

    class AbstractValidator<T> <<abstract>> {
        + ValidateAsync(instance: T) : Task<ValidationResult>
        # RuleFor(...)
    }

    class Profile <<abstract>> {
        # CreateMap<TSource, TDest>()
    }
}

' ══════════════════════════════════════════════════════════════════
' PACKAGE: Helpers
' ══════════════════════════════════════════════════════════════════
package "Helpers" #EAFAF1 {

    class PaginatedList<T> {
        + Items      : IReadOnlyList<T>
        + PageIndex  : int
        + TotalPages : int
        + TotalCount : int
        --
        + HasPreviousPage : bool  «computed»
        + HasNextPage     : bool  «computed»
        --
        + {static} CreateAsync(source: IQueryable<T>, page, size) : Task<PaginatedList<T>>
        + {static} Create(source: IEnumerable<T>, page, size) : PaginatedList<T>
    }
}

' ══════════════════════════════════════════════════════════════════
' ВІДНОСИНИ
' ══════════════════════════════════════════════════════════════════

' Inheritance
ApplicationUser      --|> IdentityUser          : «extends»
ApplicationDbContext --|> IdentityDbContext      : «extends»
RentalCreateViewModelValidator --|> AbstractValidator : «extends»
RentalMappingProfile --|> Profile               : «extends»

' Interface implementations
RentalService      ..|> IRentalService           : «implements»
MockEmailService   ..|> IEmailService            : «implements»
UnitOfWork         ..|> IUnitOfWork              : «implements»
RentalRepository   --|> GenericRepository        : «extends»
RentalRepository   ..|> IRentalRepository        : «implements»
CarRepository      --|> GenericRepository        : «extends»
CarRepository      ..|> ICarRepository           : «implements»
GenericRepository  ..|> IGenericRepository       : «implements»
IRentalRepository  --|> IGenericRepository       : «extends»
ICarRepository     --|> IGenericRepository       : «extends»

' Controller dependencies (DI)
RentalController ..> IRentalService              : «uses»
RentalController ..> IMapper                     : «uses (AutoMapper)»
RentalController ..> "IValidator<RentalCreateViewModel>" : «uses (FluentValidation)»
RentalController ..> RentalCreateViewModel       : «binds form»

' Validator
RentalCreateViewModelValidator ..> RentalCreateViewModel : «validates»

' Mapper
RentalMappingProfile ..> RentalCreateViewModel   : «maps from»
RentalMappingProfile ..> CreateRentalDto         : «maps to»
RentalMappingProfile ..> Rental                  : «maps from»
RentalMappingProfile ..> RentalDto               : «maps to»

' Service dependencies
RentalService ..> IUnitOfWork                    : «uses»
RentalService ..> IEmailService                  : «uses»
RentalService ..> CreateRentalDto                : «receives»
RentalService ..> ServiceResult                  : «returns»

' UnitOfWork
UnitOfWork --> IRentalRepository                 : «owns»
UnitOfWork --> ICarRepository                    : «owns»
UnitOfWork --> ApplicationDbContext              : «commits via»

' Repository → DB
GenericRepository --> ApplicationDbContext       : «uses»

' DB → Entities
ApplicationDbContext --> Rental                  : «DbSet»
ApplicationDbContext --> Car                     : «DbSet»
ApplicationDbContext --> Category                : «DbSet»
ApplicationDbContext --> Payment                 : «DbSet»

' Entity associations
Rental "many" --> "1" ApplicationUser            : userId FK
Rental "many" --> "1" Car                        : carId FK
Car "many" --> "1" Category                      : categoryId FK
Rental "0..1" --> "1" Payment                    : one-to-one
Rental --> RentalStatus                          : «uses»
Car --> CarStatus                                : «uses»
Car --> FuelType                                 : «uses»
Car --> Transmission                             : «uses»
Payment --> PaymentStatus                        : «uses»

@enduml
