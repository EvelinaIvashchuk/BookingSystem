@startuml CarRentalSystem_StateDiagram
skinparam stateFontSize 13
skinparam stateBorderColor #555
skinparam stateArrowColor #333
skinparam stateBackgroundColor #FAFAFA
skinparam shadowing false
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #888

title Car Rental System — Діаграма станів\n«Життєвий цикл оренди (Rental)»

' ══════════════════════════════════════════════════════════════════
' ПОЧАТКОВИЙ СТАН
' ══════════════════════════════════════════════════════════════════

[*] --> Validating : Користувач надсилає\nформу оренди

' ══════════════════════════════════════════════════════════════════
' СТАН: Validating (проміжний — не зберігається в БД)
' ══════════════════════════════════════════════════════════════════

state Validating {
    state "FluentValidation\n(UI-рівень)" as FV
    state "RentalService\n(бізнес-рівень)" as RS

    [*] --> FV : перевірка форми
    FV --> RS  : валідація пройшла
}

note right of Validating
  Перевірки:
  • PickupDate не в минулому
  • ReturnDate > PickupDate
  • Тривалість: 1 день – 30 днів
  • Не більше 60 днів наперед
  • Автомобіль = Available
  • Активних оренд < 3
  • Відсутність overlap по датах
  • TotalPrice = днів × PricePerDay
end note

' ══════════════════════════════════════════════════════════════════
' ПЕРЕХОДИ З Validating
' ══════════════════════════════════════════════════════════════════

Validating --> [*]          : [валідація провалилась]\nПомилка → форма
Validating --> Pending      : [всі перевірки пройдено]\nuow.CommitAsync()

' ══════════════════════════════════════════════════════════════════
' ОСНОВНІ СТАНИ (зберігаються в БД як RentalStatus)
' ══════════════════════════════════════════════════════════════════

state Pending {
    Pending : entry / надіслати email «Rental Created»
    Pending : Очікує рішення адміністратора
}

state Confirmed {
    Confirmed : entry / надіслати email «Rental Confirmed»
    Confirmed : Оренду підтверджено адміністратором
}

state Cancelled {
    Cancelled : entry / надіслати email «Rental Cancelled»
    Cancelled : CancelledAt = UtcNow
}

state Rejected {
    Rejected : entry / надіслати email «Rental Rejected»
    Rejected : AdminNote = причина відхилення (обов'язково)
}

state Expired {
    Expired : PickupDate <= UtcNow\n(оренда в минулому)
}

' ══════════════════════════════════════════════════════════════════
' ПЕРЕХОДИ МІЖ СТАНАМИ
' ══════════════════════════════════════════════════════════════════

' Адміністратор підтверджує
Pending --> Confirmed   : [Admin] Підтвердити\n[status = Pending]

' Адміністратор відхиляє
Pending --> Rejected    : [Admin] Відхилити\n[status = Pending,\nadminNote ≠ null]

' Користувач скасовує
Pending    --> Cancelled : [User] Скасувати\n[PickupDate > UtcNow]
Confirmed  --> Cancelled : [User] Скасувати\n[PickupDate > UtcNow]

' Оренда «спливає» — дата початку вже минула
Pending   --> Expired    : [system]\nPickupDate <= UtcNow
Confirmed --> Expired    : [system]\nPickupDate <= UtcNow

' ══════════════════════════════════════════════════════════════════
' ФІНАЛЬНІ СТАНИ
' ══════════════════════════════════════════════════════════════════

Cancelled --> [*]
Rejected  --> [*]
Expired   --> [*]

' ══════════════════════════════════════════════════════════════════
' ПРИМІТКИ
' ══════════════════════════════════════════════════════════════════

note bottom of Pending
  Єдиний стан, з якого
  можливий перехід у
  Confirmed або Rejected
end note

note bottom of Cancelled
  Неможливо скасувати
  оренду, яка вже
  розпочалася або минула
  (PickupDate <= UtcNow)
end note

note right of Rejected
  AdminNote обов'язковий —
  користувач отримує
  причину відхилення
  в email
end note

@enduml
