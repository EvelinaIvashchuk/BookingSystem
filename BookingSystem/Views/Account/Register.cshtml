@model RegisterViewModel
@{
    ViewData["Title"] = L["Account_Register_Title"].Value;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-person-plus text-primary" style="font-size: 3rem;"></i>
                        <h2 class="h3 fw-bold mt-2">@L["Account_CreateAccount"]</h2>
                        <p class="text-muted small">@L["Account_RegisterDesc"]</p>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <label asp-for="FirstName" class="form-label fw-semibold"></label>
                                <input asp-for="FirstName" class="form-control" placeholder="John" autocomplete="given-name" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="LastName" class="form-label fw-semibold"></label>
                                <input asp-for="LastName" class="form-control" placeholder="Smith" autocomplete="family-name" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-envelope text-muted"></i>
                                </span>
                                <input asp-for="Email" class="form-control border-start-0 ps-0"
                                       placeholder="you@example.com" autocomplete="email" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-lock text-muted"></i>
                                </span>
                                <input asp-for="Password" class="form-control border-start-0 ps-0"
                                       placeholder="@L["Account_PasswordPlaceholder"]" autocomplete="new-password" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-lock-fill text-muted"></i>
                                </span>
                                <input asp-for="ConfirmPassword" class="form-control border-start-0 ps-0"
                                       placeholder="@L["Account_RepeatPassword"]" autocomplete="new-password" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-primary btn-lg">@L["Account_CreateAccountBtn"]</button>
                        </div>
                    </form>

                    <hr class="my-4">

                    <p class="text-center text-muted small mb-0">
                        @L["Account_AlreadyHave"]
                        <a asp-action="Login" class="fw-semibold text-decoration-none">@L["Account_SignInLink"]</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
