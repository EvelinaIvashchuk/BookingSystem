@{
    ViewData["Title"] = L["Account_AccessDenied_Title"].Value;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="display-1 text-danger fw-bold mb-3">403</div>
            <h2 class="h3 fw-bold mb-2">@L["Account_AccessDenied_Title"]</h2>
            <p class="text-muted mb-4">@L["Account_AccessDeniedDesc"]</p>
            <div class="d-flex justify-content-center gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
                    <i class="bi bi-house me-1"></i> @L["Account_GoHome"]
                </a>
                @if (User.Identity?.IsAuthenticated != true)
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-box-arrow-in-right me-1"></i> @L["Account_SignInLink2"]
                    </a>
                }
            </div>
        </div>
    </div>
</div>
