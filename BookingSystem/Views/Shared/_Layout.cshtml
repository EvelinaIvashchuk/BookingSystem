<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>CarRental</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/BookingSystem.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-car-front me-1"></i>CarRental
            </a>

            @* Collapse FIRST — so on desktop nav links appear before auth block *@
            <div class="navbar-collapse collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">@L["Nav_Home"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Car" asp-action="Index">@L["Nav_Cars"]</a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Rental" asp-action="MyRentals">@L["Nav_MyRentals"]</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-area="" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-shield-lock me-1"></i>@L["Nav_AdminPanel"]
                                </a>
                            </li>
                        }
                    }
                </ul>
            </div>

            @* Always visible: auth + toggler *@
            <div class="d-flex align-items-center gap-2 ms-auto">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="text-muted small d-none d-sm-inline">
                        <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                    </span>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-box-arrow-right me-1"></i>@L["Nav_Logout"]
                        </button>
                    </form>
                }
                else
                {
                    <a class="btn btn-outline-primary btn-sm" asp-controller="Account" asp-action="Login">@L["Nav_Login"]</a>
                    <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Register">@L["Nav_Register"]</a>
                }

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container footer-inner">
        <span>&copy; 2026 CarRental &mdash; <a asp-area="" asp-controller="Home" asp-action="Privacy">@L["Nav_Privacy"]</a></span>

        <form id="langForm" asp-controller="Language" asp-action="Set" method="post" class="footer-lang">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
            <input type="hidden" id="cultureInput" name="culture" value="" />
            <div class="lang-switcher-container" title="@L["Nav_ChangeLanguage"]">
                <input type="checkbox" id="langToggle" class="lang-input" @(!System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("uk") ? "checked" : "")>
                <label for="langToggle" class="lang-flag-label flag-ua">🇺🇦</label>
                <label for="langToggle" class="lang-switch">
                    <span class="lang-slider"></span>
                </label>
                <label for="langToggle" class="lang-flag-label flag-en">🇺🇸</label>
            </div>
        </form>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
<partial name="_Toasts" />
<script>
    document.getElementById('langToggle').addEventListener('change', function() {
        const culture = this.checked ? 'en-US' : 'uk';
        document.getElementById('cultureInput').value = culture;
        document.getElementById('langForm').submit();
    });
</script>
</body>
</html>
