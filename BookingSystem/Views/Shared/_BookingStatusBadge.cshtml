@model BookingStatus
@*
    Reusable booking status badge with icon + colour.
    Usage: <partial name="_BookingStatusBadge" model="booking.Status" />
*@

@switch (Model)
{
    case BookingStatus.Pending:
        <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
            <i class="bi bi-clock me-1"></i>Pending
        </span>
        break;

    case BookingStatus.Confirmed:
        <span class="badge bg-success-subtle text-success border border-success-subtle">
            <i class="bi bi-check-circle me-1"></i>Confirmed
        </span>
        break;

    case BookingStatus.Rejected:
        <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
            <i class="bi bi-x-circle me-1"></i>Rejected
        </span>
        break;

    case BookingStatus.Cancelled:
        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
            <i class="bi bi-dash-circle me-1"></i>Cancelled
        </span>
        break;

    default:
        <span class="badge bg-light text-dark border">@Model</span>
        break;
}
