@model Car
@{
    ViewData["Title"] = Model.FullName;
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Browse Cars</a></li>
            @if (Model.Category != null)
            {
                <li class="breadcrumb-item"><a asp-action="Index" asp-route-categoryId="@Model.CategoryId">@Model.Category.Name</a></li>
            }
            <li class="breadcrumb-item active" aria-current="page">@Model.FullName</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-7 mb-4 mb-lg-0">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm border" alt="@Model.FullName" style="width: 100%; max-height: 450px; object-fit: cover;">
            }
            else
            {
                <div class="bg-light rounded d-flex align-items-center justify-content-center border shadow-sm mb-4" style="width: 100%; height: 350px;">
                    <i class="bi bi-car-front text-muted opacity-25" style="font-size: 8rem;"></i>
                </div>
            }

            <div class="mt-5">
                <h3 class="h4 mb-3 border-bottom pb-2">Description</h3>
                <p class="lead text-muted">@Model.Description</p>

                <div class="row mt-4">
                    <div class="col-sm-6 mb-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary-subtle p-2 rounded me-3 text-primary">
                                <i class="bi bi-geo-alt fs-4"></i>
                            </div>
                            <div>
                                <small class="text-uppercase text-muted fw-bold d-block">Location</small>
                                <span>@Model.Location</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary-subtle p-2 rounded me-3 text-primary">
                                <i class="bi bi-people fs-4"></i>
                            </div>
                            <div>
                                <small class="text-uppercase text-muted fw-bold d-block">Seats</small>
                                <span>@Model.Seats</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary-subtle p-2 rounded me-3 text-primary">
                                <i class="bi bi-fuel-pump fs-4"></i>
                            </div>
                            <div>
                                <small class="text-uppercase text-muted fw-bold d-block">Fuel Type</small>
                                <span>@Model.FuelType</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary-subtle p-2 rounded me-3 text-primary">
                                <i class="bi bi-gear fs-4"></i>
                            </div>
                            <div>
                                <small class="text-uppercase text-muted fw-bold d-block">Transmission</small>
                                <span>@Model.Transmission</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0 sticky-top" style="top: 20px; z-index: 100;">
                <div class="card-body p-4">
                    <h2 class="h3 fw-bold mb-2">@Model.FullName</h2>
                    <div class="fs-4 text-primary fw-bold mb-4">@Model.PricePerDay.ToString("N0") ₴ <span class="fs-6 text-muted fw-normal">/ day</span></div>

                    <div class="mb-4">
                        <span class="text-uppercase text-muted fw-bold d-block small mb-2">Status</span>
                        @if (Model.Status == CarStatus.Available)
                        {
                            <span class="badge bg-success-subtle text-success border border-success-subtle p-2 px-3 fs-6">
                                <i class="bi bi-check-circle me-1"></i> Available
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle p-2 px-3 fs-6">
                                <i class="bi bi-exclamation-triangle me-1"></i> @Model.Status
                            </span>
                        }
                    </div>

                    <div class="d-grid gap-3">
                        @if (Model.Status == CarStatus.Available)
                        {
                            <a asp-controller="Rental" asp-action="Create" asp-route-carId="@Model.Id" class="btn btn-primary btn-lg py-3 fw-bold">
                                <i class="bi bi-car-front me-2"></i>Rent Now
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-lg py-3 fw-bold" disabled>
                                Currently Unavailable
                            </button>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary py-2 mt-2">
                            Back to List
                        </a>
                    </div>

                    <div class="mt-4 pt-4 border-top">
                        <h5 class="h6 fw-bold mb-3">Includes</h5>
                        <ul class="list-unstyled mb-0 small text-muted">
                            <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i> Full insurance</li>
                            <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i> 24/7 roadside assistance</li>
                            <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i> Free cancellation</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
