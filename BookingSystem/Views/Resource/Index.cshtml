@using BookingSystem.Helpers
@using Microsoft.AspNetCore.Mvc.Rendering
@model PaginatedList<BookingSystem.Models.Resource>
@{
    ViewData["Title"] = "Available Resources";
    var categories = ViewBag.Categories as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
}

<div class="container py-4">
    <!-- Header + Filter Bar -->
    <div class="row mb-4 align-items-end">
        <div class="col-lg-4 mb-3 mb-lg-0">
            <h1 class="h2 mb-0">Browse Resources</h1>
            <p class="text-muted small mb-0">@Model.TotalCount available resources found.</p>
        </div>
        <div class="col-lg-8">
            <form asp-action="Index" method="get">
                <div class="row g-2">
                    <div class="col-md-4">
                        <select name="categoryId" class="form-select" onchange="this.form.submit()" asp-items="categories">
                            <option value="">All Categories</option>
                        </select>
                    </div>
                    <div class="col-md-5">
                        <input type="text" name="search" value="@ViewBag.Search"
                               class="form-control" placeholder="Search by name or description..." />
                    </div>
                    <div class="col-md-3 d-flex gap-1">
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-search me-1"></i> Search
                        </button>
                        @if (!string.IsNullOrEmpty((string?)ViewBag.Search) || ViewBag.CategoryId != null)
                        {
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg"></i>
                            </a>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Cards -->
    @if (!Model.Any())
    {
        <div class="alert alert-info shadow-sm" role="alert">
            <i class="bi bi-info-circle me-2"></i>
            No resources match your search or filter.
            <a asp-action="Index" class="alert-link ms-2">View all resources</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var r in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 transition-hover">
                        @if (!string.IsNullOrEmpty(r.ImageUrl))
                        {
                            <img src="@r.ImageUrl" class="card-img-top" alt="@r.Name" style="height: 180px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                                <i class="bi bi-image text-muted opacity-50" style="font-size: 3rem;"></i>
                            </div>
                        }
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">@r.Name</h5>
                                <span class="badge bg-success-subtle text-success border border-success-subtle">Available</span>
                            </div>
                            <p class="card-text text-muted small text-truncate-2 mb-3">
                                @r.Description
                            </p>
                            <div class="d-flex align-items-center text-secondary small mb-1">
                                <i class="bi bi-geo-alt me-1"></i> @r.Location
                                <span class="mx-2 text-muted">|</span>
                                <i class="bi bi-people me-1"></i> Cap: @r.Capacity
                            </div>
                            @if (r.Category != null)
                            {
                                <span class="badge bg-light text-dark border mt-2">@r.Category.Name</span>
                            }
                        </div>
                        <div class="card-footer bg-transparent border-top-0 pb-3">
                            <div class="d-grid gap-2">
                                <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-outline-primary">View Details</a>
                                <a asp-controller="Booking" asp-action="Create" asp-route-resourceId="@r.Id" class="btn btn-primary">Book Now</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        ViewData["PageIndex"]  = Model.PageIndex;
        ViewData["TotalPages"] = Model.TotalPages;
        ViewData["Action"]     = "Index";
        ViewData["RouteValues"] = new Dictionary<string, string>
        {
            ["search"]     = ViewBag.Search ?? "",
            ["categoryId"] = ViewBag.CategoryId?.ToString() ?? ""
        };
        <partial name="_Pagination" />
    }
</div>

<style>
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .transition-hover:hover {
        transform: translateY(-5px);
        transition: transform 0.2s ease-in-out;
    }
</style>
