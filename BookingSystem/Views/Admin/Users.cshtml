@model IEnumerable<(BookingSystem.Models.ApplicationUser User, IList<string> Roles)>
@using System.Security.Claims
@{
    ViewData["Title"] = "Manage Users";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-0">Manage Users</h1>
            <p class="text-muted small">View all registered accounts, activate/deactivate, or promote to Admin.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">User</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Registered</th>
                            <th>Status</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-people fs-3 d-block mb-2"></i>No users found.
                                </td>
                            </tr>
                        }
                        @foreach (var (user, roles) in Model)
                        {
                            var isSelf    = user.Id == currentUserId;
                            var isAdmin   = roles.Contains("Admin");

                            <tr class="@(!user.IsActive ? "table-secondary text-muted" : "")">
                                <td class="ps-3">
                                    <div class="fw-semibold">
                                        @user.FullName
                                        @if (isSelf)
                                        {
                                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle ms-1">You</span>
                                        }
                                    </div>
                                    <div class="text-muted small">ID: @user.Id[..8]…</div>
                                </td>
                                <td class="small">@user.Email</td>
                                <td>
                                    @foreach (var role in roles)
                                    {
                                        <span class="badge @(role == "Admin" ? "bg-danger" : "bg-secondary") me-1">@role</span>
                                    }
                                </td>
                                <td class="small text-muted">@user.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">
                                            <i class="bi bi-check-circle me-1"></i>Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
                                            <i class="bi bi-dash-circle me-1"></i>Inactive
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (!isSelf)
                                    {
                                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                                            @* Activate / Deactivate *@
                                            <form asp-action="ToggleUserActive" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <input type="hidden" name="isActive" value="@(!user.IsActive)" />
                                                @if (user.IsActive)
                                                {
                                                    <button type="submit" class="btn btn-sm btn-outline-warning"
                                                            onclick="return confirm('Deactivate @user.FullName? They will not be able to log in.')">
                                                        <i class="bi bi-person-slash me-1"></i>Deactivate
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                                        <i class="bi bi-person-check me-1"></i>Activate
                                                    </button>
                                                }
                                            </form>

                                            @* Promote to Admin (only for non-admin users) *@
                                            @if (!isAdmin)
                                            {
                                                <form asp-action="PromoteToAdmin" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                                            onclick="return confirm('Promote @user.FullName to Admin? This grants full system access.')">
                                                        <i class="bi bi-shield-plus me-1"></i>Make Admin
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
