@model AdminRejectViewModel
@{
    ViewData["Title"] = L["Admin_RejectRental_Title"].Value;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-danger text-white p-4 border-0 rounded-top">
                    <h2 class="h4 mb-0"><i class="bi bi-x-circle me-2"></i> @L["Admin_RejectRentalHeader"]</h2>
                </div>
                <div class="card-body p-4 p-md-5">
                    <div class="alert alert-warning mb-4">
                        <i class="bi bi-info-circle me-2"></i> @L["Admin_RejectAboutTo"]
                        <strong>@Model.CarName</strong> @L["Admin_RejectBy"] <strong>@Model.UserFullName</strong>.
                    </div>

                    <form asp-action="RejectRental" method="post">
                        <input type="hidden" asp-for="RentalId" />
                        <input type="hidden" asp-for="CarName" />
                        <input type="hidden" asp-for="UserFullName" />

                        <div class="mb-5">
                            <label asp-for="AdminNote" class="form-label fw-bold">@L["Admin_ReasonForRejection"]</label>
                            <textarea asp-for="AdminNote" class="form-control" rows="4"
                                      placeholder="@L["Admin_RejectPlaceholder"]"></textarea>
                            <span asp-validation-for="AdminNote" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end pt-3 border-top">
                            <a asp-action="Rentals" class="btn btn-outline-secondary px-4 me-md-2">@L["Admin_Cancel"]</a>
                            <button type="submit" class="btn btn-danger px-5 shadow">@L["Admin_RejectRequest"]</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
