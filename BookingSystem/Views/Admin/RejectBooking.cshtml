@model AdminRejectViewModel
@{
    ViewData["Title"] = "Reject Booking Request";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-danger text-white p-4 border-0 rounded-top">
                    <h2 class="h4 mb-0"><i class="bi bi-x-circle me-2"></i> Reject Booking</h2>
                </div>
                <div class="card-body p-4 p-md-5">
                    <div class="alert alert-warning mb-4">
                        <i class="bi bi-info-circle me-2"></i> You are about to reject the booking for 
                        <strong>@Model.ResourceName</strong> by <strong>@Model.UserFullName</strong>.
                    </div>

                    <form asp-action="RejectBooking" method="post">
                        <input type="hidden" asp-for="BookingId" />
                        <input type="hidden" asp-for="ResourceName" />
                        <input type="hidden" asp-for="UserFullName" />

                        <div class="mb-5">
                            <label asp-for="AdminNote" class="form-label fw-bold">Reason for Rejection</label>
                            <textarea asp-for="AdminNote" class="form-control" rows="4" 
                                      placeholder="Explain why this request is being rejected. This will be visible to the user..."></textarea>
                            <span asp-validation-for="AdminNote" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end pt-3 border-top">
                            <a asp-action="Bookings" class="btn btn-outline-secondary px-4 me-md-2">Cancel</a>
                            <button type="submit" class="btn btn-danger px-5 shadow">Reject Request</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}