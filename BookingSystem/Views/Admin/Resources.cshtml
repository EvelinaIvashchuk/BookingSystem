@model IEnumerable<Resource>
@{
    ViewData["Title"] = "Manage Resources";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-0">Manage Resources</h1>
            <p class="text-muted small">View and manage all bookable resources in the system.</p>
        </div>
        <a asp-action="CreateResource" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i> Add New Resource
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Resource</th>
                            <th>Category</th>
                            <th>Capacity</th>
                            <th>Status</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                    No resources found.
                                    <a asp-action="CreateResource" class="d-block mt-2">Add the first resource</a>
                                </td>
                            </tr>
                        }
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-bold">@r.Name</div>
                                    <div class="text-muted small">@r.Location</div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">@r.Category?.Name</span>
                                </td>
                                <td>@r.Capacity</td>
                                <td>
                                    @if (r.Status == ResourceStatus.Available)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">Available</span>
                                    }
                                    else if (r.Status == ResourceStatus.UnderMaintenance)
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Maintenance</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">@r.Status</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditResource" asp-route-id="@r.Id" class="btn btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <div class="dropdown d-inline">
                                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                                Status
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <form asp-action="SetResourceStatus" method="post">
                                                        <input type="hidden" name="resourceId" value="@r.Id" />
                                                        <input type="hidden" name="status" value="@ResourceStatus.Available" />
                                                        <button type="submit" class="dropdown-item @(r.Status == ResourceStatus.Available ? "disabled" : "")">Available</button>
                                                    </form>
                                                </li>
                                                <li>
                                                    <form asp-action="SetResourceStatus" method="post">
                                                        <input type="hidden" name="resourceId" value="@r.Id" />
                                                        <input type="hidden" name="status" value="@ResourceStatus.UnderMaintenance" />
                                                        <button type="submit" class="dropdown-item @(r.Status == ResourceStatus.UnderMaintenance ? "disabled" : "")">Under Maintenance</button>
                                                    </form>
                                                </li>
                                                <li>
                                                    <form asp-action="SetResourceStatus" method="post">
                                                        <input type="hidden" name="resourceId" value="@r.Id" />
                                                        <input type="hidden" name="status" value="@ResourceStatus.Retired" />
                                                        <button type="submit" class="dropdown-item @(r.Status == ResourceStatus.Retired ? "disabled" : "")">Retired</button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>