@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">Dashboard Overview</h1>
        <div class="text-muted small">@DateTime.Now.ToLongDateString()</div>
    </div>

    <!-- Stats Row -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 text-center">
                    <div class="display-6 text-primary mb-2">@Model.TotalResources</div>
                    <div class="text-uppercase text-muted small fw-bold">Total Resources</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 text-center">
                    <div class="display-6 text-success mb-2">@Model.AvailableResources</div>
                    <div class="text-uppercase text-muted small fw-bold">Available Now</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 text-center">
                    <div class="display-6 text-warning mb-2">@Model.PendingBookings</div>
                    <div class="text-uppercase text-muted small fw-bold">Pending Requests</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 text-center">
                    <div class="display-6 text-info mb-2">@Model.TodaysBookings</div>
                    <div class="text-uppercase text-muted small fw-bold">Bookings Today</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Recent Pending Bookings -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom p-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">Recent Pending Requests</h5>
                    <a asp-action="Bookings" asp-route-status="Pending" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Resource</th>
                                    <th>User</th>
                                    <th>Date & Time</th>
                                    <th class="text-end pe-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.RecentPending.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted small italic">No pending requests at the moment.</td>
                                    </tr>
                                }
                                @foreach (var b in Model.RecentPending)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <div class="fw-semibold">@b.Resource?.Name</div>
                                            <div class="text-muted extra-small">@b.Resource?.Location</div>
                                        </td>
                                        <td>
                                            <div class="small">@b.User?.UserName</div>
                                            <div class="text-muted extra-small">@b.User?.Email</div>
                                        </td>
                                        <td>
                                            <div class="small">@b.StartTime?.ToString("MMM dd, HH:mm")</div>
                                            <div class="text-muted extra-small">@b.EndTime?.ToString("HH:mm") (@((b.EndTime - b.StartTime)?.TotalHours.ToString("0.0")) hrs)</div>
                                        </td>
                                        <td class="text-end pe-3">
                                            <div class="btn-group btn-group-sm">
                                                <form asp-action="ConfirmBooking" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@b.Id" />
                                                    <button type="submit" class="btn btn-success" title="Approve">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                </form>
                                                <a asp-action="RejectBooking" asp-route-id="@b.Id" class="btn btn-outline-danger" title="Reject">
                                                    <i class="bi bi-x-lg"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Links -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom p-3">
                    <h5 class="mb-0 fw-bold">Quick Actions</h5>
                </div>
                <div class="card-body p-3">
                    <div class="d-grid gap-2">
                        <a asp-action="CreateResource" class="btn btn-primary text-start">
                            <i class="bi bi-plus-circle me-2"></i> Add New Resource
                        </a>
                        <a asp-action="Resources" class="btn btn-outline-secondary text-start">
                            <i class="bi bi-list-task me-2"></i> Manage All Resources
                        </a>
                        <a asp-action="Bookings" class="btn btn-outline-secondary text-start">
                            <i class="bi bi-calendar-event me-2"></i> Review All Bookings
                        </a>
                        <a asp-action="Users" class="btn btn-outline-secondary text-start">
                            <i class="bi bi-people me-2"></i> Manage Users
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body p-4">
                    <h6>System Status</h6>
                    <div class="d-flex align-items-center mt-3">
                        <div class="bg-white rounded-circle me-2" style="width: 10px; height: 10px;"></div>
                        <span class="small">All systems operational</span>
                    </div>
                    <div class="mt-3 small opacity-75">
                        <i class="bi bi-info-circle me-1"></i> Database: Connected
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .extra-small { font-size: 0.75rem; }
</style>