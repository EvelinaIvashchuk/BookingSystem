@model AdminDashboardViewModel
@{
    ViewData["Title"] = L["Admin_Dashboard_Title"].Value;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">@L["Admin_DashboardOverview"]</h1>
        <div class="text-muted small">@DateTime.Now.ToLongDateString()</div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 text-center">
                    <div class="display-6 text-primary mb-2">@Model.TotalCars</div>
                    <div class="text-uppercase text-muted small fw-bold">@L["Admin_TotalCars"]</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 text-center">
                    <div class="display-6 text-success mb-2">@Model.AvailableCars</div>
                    <div class="text-uppercase text-muted small fw-bold">@L["Admin_AvailableNow"]</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 text-center">
                    <div class="display-6 text-warning mb-2">@Model.PendingRentals</div>
                    <div class="text-uppercase text-muted small fw-bold">@L["Admin_PendingRequests"]</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 text-center">
                    <div class="display-6 text-info mb-2">@Model.TodaysRentals</div>
                    <div class="text-uppercase text-muted small fw-bold">@L["Admin_PickupsToday"]</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom p-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">@L["Admin_RecentPending"]</h5>
                    <a asp-action="Rentals" asp-route-status="Pending" class="btn btn-sm btn-outline-primary">@L["Admin_ViewAll"]</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">@L["Admin_Car"]</th>
                                    <th>@L["Admin_User"]</th>
                                    <th>@L["Admin_Dates"]</th>
                                    <th class="text-end pe-3">@L["Admin_Actions"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.RecentPending.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted small italic">@L["Admin_NoPending"]</td>
                                    </tr>
                                }
                                @foreach (var r in Model.RecentPending)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <div class="fw-semibold">@r.Car?.FullName</div>
                                            <div class="text-muted extra-small">@r.Car?.Location</div>
                                        </td>
                                        <td>
                                            <div class="small">@r.User?.UserName</div>
                                            <div class="text-muted extra-small">@r.User?.Email</div>
                                        </td>
                                        <td>
                                            <div class="small">@r.PickupDate?.ToString("dd MMM") – @r.ReturnDate?.ToString("dd MMM yyyy")</div>
                                            <div class="text-muted extra-small">@r.DurationDays @L["Rental_Days"] | @r.TotalPrice.ToString("N0") ₴</div>
                                        </td>
                                        <td class="text-end pe-3">
                                            <div class="btn-group btn-group-sm">
                                                <form asp-action="ConfirmRental" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@r.Id" />
                                                    <button type="submit" class="btn btn-success" title="Approve">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                </form>
                                                <a asp-action="RejectRental" asp-route-id="@r.Id" class="btn btn-outline-danger" title="Reject">
                                                    <i class="bi bi-x-lg"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom p-3">
                    <h5 class="mb-0 fw-bold">@L["Admin_QuickActions"]</h5>
                </div>
                <div class="card-body p-3">
                    <div class="d-grid gap-2">
                        <a asp-action="CreateCar" class="btn btn-primary text-start">
                            <i class="bi bi-plus-circle me-2"></i> @L["Admin_AddNewCar"]
                        </a>
                        <a asp-action="Cars" class="btn btn-outline-secondary text-start">
                            <i class="bi bi-car-front me-2"></i> @L["Admin_ManageAllCars"]
                        </a>
                        <a asp-action="Rentals" class="btn btn-outline-secondary text-start">
                            <i class="bi bi-calendar-event me-2"></i> @L["Admin_ReviewAllRentals"]
                        </a>
                        <a asp-action="Users" class="btn btn-outline-secondary text-start">
                            <i class="bi bi-people me-2"></i> @L["Admin_ManageUsers"]
                        </a>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body p-4">
                    <h6>@L["Admin_SystemStatus"]</h6>
                    <div class="d-flex align-items-center mt-3">
                        <div class="bg-white rounded-circle me-2" style="width: 10px; height: 10px;"></div>
                        <span class="small">@L["Admin_AllSystemsOp"]</span>
                    </div>
                    <div class="mt-3 small opacity-75">
                        <i class="bi bi-info-circle me-1"></i> @L["Admin_DbConnected"]
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .extra-small { font-size: 0.75rem; }
</style>
