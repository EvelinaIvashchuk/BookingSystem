@using BookingSystem.Helpers
@model PaginatedList<Booking>
@{
    ViewData["Title"] = "Manage Bookings";
    var filterStatus = ViewBag.FilterStatus as BookingStatus?;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-0">Manage Bookings</h1>
            <p class="text-muted small">@Model.TotalCount booking(s) found.</p>
        </div>
        <div class="btn-group shadow-sm">
            <a asp-action="Bookings"
               class="btn btn-outline-secondary @(filterStatus == null ? "active" : "")">All</a>
            <a asp-action="Bookings" asp-route-status="Pending"
               class="btn btn-outline-secondary @(filterStatus == BookingStatus.Pending ? "active" : "")">Pending</a>
            <a asp-action="Bookings" asp-route-status="Confirmed"
               class="btn btn-outline-secondary @(filterStatus == BookingStatus.Confirmed ? "active" : "")">Confirmed</a>
            <a asp-action="Bookings" asp-route-status="Cancelled"
               class="btn btn-outline-secondary @(filterStatus == BookingStatus.Cancelled ? "active" : "")">Cancelled</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Resource</th>
                            <th>User</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                            <th>Status</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">No bookings found for the selected filter.</td>
                            </tr>
                        }
                        @foreach (var b in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-bold">@b.Resource?.Name</div>
                                    <div class="text-muted small">@b.Resource?.Location</div>
                                </td>
                                <td>
                                    <div class="small">@b.User?.FullName</div>
                                    <div class="text-muted extra-small">@b.User?.Email</div>
                                </td>
                                <td class="small">@b.StartTime?.ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="small">@b.EndTime?.ToString("MMM dd, yyyy HH:mm")</td>
                                <td><partial name="_BookingStatusBadge" model="b.Status" /></td>
                                <td class="text-end pe-3">
                                    @if (b.Status == BookingStatus.Pending)
                                    {
                                        <div class="btn-group btn-group-sm shadow-sm">
                                            <form asp-action="ConfirmBooking" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@b.Id" />
                                                <button type="submit" class="btn btn-success" title="Approve">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                            <a asp-action="RejectBooking" asp-route-id="@b.Id" class="btn btn-outline-danger" title="Reject">
                                                <i class="bi bi-x-lg"></i>
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @{
        ViewData["PageIndex"]   = Model.PageIndex;
        ViewData["TotalPages"]  = Model.TotalPages;
        ViewData["Action"]      = "Bookings";
        ViewData["RouteValues"] = new Dictionary<string, string>
        {
            ["status"] = filterStatus?.ToString() ?? ""
        };
    }
    <partial name="_Pagination" />
</div>

<style>
    .extra-small { font-size: 0.75rem; }
</style>
