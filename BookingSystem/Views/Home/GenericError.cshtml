@{
    ViewData["Title"] = L["Error_Generic_Title"].Value;
    var code = ViewBag.StatusCode as int? ?? 500;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="display-1 fw-bold text-danger mb-3">@(code)</div>
            <h2 class="h3 fw-bold mb-2">@L["Error_Generic_Desc"]</h2>
            <p class="text-muted mb-4">@L["Error_Generic_Details"]</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
                <i class="bi bi-house me-1"></i> @L["Common_GoHome"]
            </a>
        </div>
    </div>
</div>
