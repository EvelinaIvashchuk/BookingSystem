@{
    ViewData["Title"] = "Page Not Found";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="display-1 fw-bold text-primary mb-3">404</div>
            <h2 class="h3 fw-bold mb-2">Page Not Found</h2>
            <p class="text-muted mb-4">
                Sorry, the page you're looking for doesn't exist or has been moved.
            </p>
            <div class="d-flex justify-content-center gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
                    <i class="bi bi-house me-1"></i> Go Home
                </a>
                <a asp-controller="Resource" asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-search me-1"></i> Browse Resources
                </a>
            </div>
        </div>
    </div>
</div>
