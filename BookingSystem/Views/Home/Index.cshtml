@model IEnumerable<Car>
@{
    ViewData["Title"] = L["Home_Title"].Value;
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold">@L["Home_Welcome"]</h1>
        <p class="lead text-muted">@L["Home_Subtitle"]</p>
        <hr class="mx-auto" style="width: 100px; border-width: 3px; border-color: var(--bs-primary);">
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="display-6 text-primary mb-3">
                    <i class="bi bi-search"></i>
                </div>
                <h4>@L["Home_SearchCars"]</h4>
                <p class="text-muted">@L["Home_SearchCarsDesc"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="display-6 text-success mb-3">
                    <i class="bi bi-calendar-check"></i>
                </div>
                <h4>@L["Home_EasyRental"]</h4>
                <p class="text-muted">@L["Home_EasyRentalDesc"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="display-6 text-info mb-3">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h4>@L["Home_SecureReliable"]</h4>
                <p class="text-muted">@L["Home_SecureReliableDesc"]</p>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="mt-5 pt-4">
            <div class="d-flex justify-content-between align-items-end mb-4">
                <h2 class="h3 mb-0">@L["Home_FeaturedCars"]</h2>
                <a asp-controller="Car" asp-action="Index" class="btn btn-link text-decoration-none">@L["Home_ViewAll"] <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="row row-cols-1 row-cols-md-3 g-4">
                @foreach (var c in Model.Take(3))
                {
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title">@c.FullName</h5>
                                <p class="card-text text-muted small">@c.Description</p>
                                <div class="fw-bold text-primary">@c.PricePerDay.ToString("N0") @L["Home_PerDay"]</div>
                                <a asp-controller="Car" asp-action="Details" asp-route-id="@c.Id" class="stretched-link"></a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="text-center mt-5">
        <a asp-controller="Car" asp-action="Index" class="btn btn-primary btn-lg px-5">@L["Home_BrowseCars"]</a>
    </div>
</div>
