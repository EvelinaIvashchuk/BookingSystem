@using BookingSystem.Helpers
@model IEnumerable<Car>
@{
    ViewData["Title"] = L["Home_Title"].Value;
}

<style>
    .hero-section {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        background: linear-gradient(135deg, #0a0e1a 0%, #111827 40%, #0d1b3e 100%);
        position: relative;
        overflow: hidden;
        padding: 6rem 1rem 5rem;
        margin-bottom: 3.5rem;
    }

    /* Dot grid overlay */
    .hero-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1px, transparent 1px);
        background-size: 32px 32px;
        pointer-events: none;
        z-index: 1;
    }

    /* Glowing orbs */
    .hero-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(90px);
        pointer-events: none;
        z-index: 0;
    }
    .hero-orb-1 {
        width: 500px; height: 500px;
        background: radial-gradient(circle, #4361ee, transparent 70%);
        opacity: 0.35;
        top: -150px; left: -100px;
        animation: floatOrb1 22s ease-in-out infinite;
    }
    .hero-orb-2 {
        width: 380px; height: 380px;
        background: radial-gradient(circle, #7b2ff7, transparent 70%);
        opacity: 0.28;
        top: 30%; right: -80px;
        animation: floatOrb2 18s ease-in-out infinite;
    }
    .hero-orb-3 {
        width: 320px; height: 320px;
        background: radial-gradient(circle, #00c9ff, transparent 70%);
        opacity: 0.2;
        bottom: -80px; left: 35%;
        animation: floatOrb3 25s ease-in-out infinite;
    }

    @@keyframes floatOrb1 {
        0%   { transform: translate(0px, 0px); }
        33%  { transform: translate(40px, -30px); }
        66%  { transform: translate(-20px, 40px); }
        100% { transform: translate(0px, 0px); }
    }
    @@keyframes floatOrb2 {
        0%   { transform: translate(0px, 0px); }
        50%  { transform: translate(-50px, 20px); }
        100% { transform: translate(0px, 0px); }
    }
    @@keyframes floatOrb3 {
        0%   { transform: translate(0px, 0px); }
        40%  { transform: translate(30px, -40px); }
        80%  { transform: translate(-30px, 20px); }
        100% { transform: translate(0px, 0px); }
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-title {
        font-size: clamp(2.2rem, 5vw, 3.8rem);
        font-weight: 800;
        color: #ffffff;
        letter-spacing: -0.02em;
        line-height: 1.15;
    }
    .hero-title span {
        background: linear-gradient(90deg, #60a5fa, #a78bfa, #38bdf8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .hero-subtitle {
        color: rgba(255,255,255,0.6);
        font-size: 1.15rem;
        max-width: 500px;
        margin: 0 auto;
    }
    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        color: rgba(255,255,255,0.7);
        font-size: 0.8rem;
        padding: 0.35rem 0.85rem;
        border-radius: 100px;
        margin-bottom: 1.5rem;
        backdrop-filter: blur(4px);
    }
    .hero-cta {
        background: linear-gradient(135deg, #4361ee, #7b2ff7);
        border: none;
        padding: 0.75rem 2.2rem;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 50px;
        color: white;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 20px rgba(67, 97, 238, 0.45);
    }
    .hero-cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(67, 97, 238, 0.6);
        color: white;
    }

    /* ── Features ── */
    .step-card {
        border-radius: 1.25rem;
        border: 1px solid rgba(0,0,0,0.06);
        transition: transform 0.25s, box-shadow 0.25s;
        position: relative;
        overflow: hidden;
    }
    .step-card:hover { transform: translateY(-5px); box-shadow: 0 16px 40px rgba(0,0,0,0.1) !important; }
    .step-num {
        font-size: 5rem;
        font-weight: 900;
        line-height: 1;
        letter-spacing: -4px;
        opacity: 0.06;
        position: absolute;
        top: 0.5rem; right: 1rem;
        user-select: none;
    }
    .step-icon-wrap {
        width: 52px; height: 52px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 1rem;
    }

    /* ── Car cards ── */
    .car-card {
        border-radius: 1.25rem;
        border: 1px solid rgba(0,0,0,0.06);
        transition: transform 0.25s, box-shadow 0.25s;
        overflow: hidden;
    }
    .car-card:hover { transform: translateY(-5px); box-shadow: 0 16px 40px rgba(0,0,0,0.12) !important; }
    .car-thumb {
        height: 160px;
        object-fit: cover;
        width: 100%;
    }
    .car-thumb-placeholder {
        height: 160px;
        display: flex; align-items: center; justify-content: center;
        font-size: 3.5rem;
        color: rgba(255,255,255,0.35);
        position: relative;
        overflow: hidden;
    }
    .car-thumb-placeholder::after {
        content: '';
        position: absolute; inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Ccircle cx='20' cy='20' r='2'/%3E%3C/g%3E%3C/svg%3E") repeat;
    }
    .car-spec-badge {
        display: inline-flex; align-items: center; gap: 0.3rem;
        font-size: 0.75rem;
        background: #f1f5f9;
        color: #475569;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
        font-weight: 500;
    }
    .car-price {
        font-size: 1.25rem; font-weight: 700;
        color: #1d4ed8;
    }
    .car-price span { font-size: 0.75rem; font-weight: 400; color: #94a3b8; }
    .btn-details {
        background: linear-gradient(135deg, #4361ee, #7b2ff7);
        border: none; color: white; font-size: 0.82rem; font-weight: 600;
        padding: 0.45rem 1.1rem; border-radius: 8px;
        transition: opacity 0.2s, transform 0.2s;
        white-space: nowrap;
    }
    .btn-details:hover { opacity: 0.88; transform: translateY(-1px); color: white; }

    /* ── Section label ── */
    .section-eyebrow {
        font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em;
        text-transform: uppercase; color: #6366f1;
        margin-bottom: 0.35rem;
    }
</style>

@* ─── HERO ─────────────────────────────────────── *@
<div class="hero-section">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>

    <div class="hero-content text-center">
        <div class="hero-badge">
            <i class="bi bi-star-fill text-warning"></i>
            CarRental — @L["Home_Subtitle"]
        </div>
        <h1 class="hero-title mb-3">
            @{
                var welcome = L["Home_Welcome"].Value;
                var brand = "CarRental";
                int brandIdx = welcome.IndexOf(brand, StringComparison.OrdinalIgnoreCase);
            }
            @if (brandIdx >= 0)
            {
                @welcome.Substring(0, brandIdx)<span>@brand</span>@welcome.Substring(brandIdx + brand.Length)
            }
            else
            {
                @welcome
            }
        </h1>
        <p class="hero-subtitle mb-4 mx-auto">@L["Home_SearchCarsDesc"]</p>
        <a asp-controller="Car" asp-action="Index" class="hero-cta">
            @L["Home_BrowseCars"] <i class="bi bi-arrow-right"></i>
        </a>
    </div>
</div>

@* ─── FEATURES ─────────────────────────────────── *@
<div class="container">
    <div class="text-center mb-4">
        <div class="section-eyebrow">@L["Home_HowItWorks"]</div>
        <h2 class="h3 fw-bold">@L["Home_WhyChooseUs"]</h2>
    </div>
    <div class="row g-4 justify-content-center mb-5">
        <div class="col-md-4">
            <div class="card step-card border-0 shadow-sm h-100 p-4">
                <div class="step-num text-primary">01</div>
                <div class="step-icon-wrap bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-search"></i>
                </div>
                <h5 class="fw-bold mb-2">@L["Home_SearchCars"]</h5>
                <p class="text-muted small mb-0">@L["Home_SearchCarsDesc"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card step-card border-0 shadow-sm h-100 p-4">
                <div class="step-num text-success">02</div>
                <div class="step-icon-wrap bg-success bg-opacity-10 text-success">
                    <i class="bi bi-calendar-check"></i>
                </div>
                <h5 class="fw-bold mb-2">@L["Home_EasyRental"]</h5>
                <p class="text-muted small mb-0">@L["Home_EasyRentalDesc"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card step-card border-0 shadow-sm h-100 p-4">
                <div class="step-num text-info">03</div>
                <div class="step-icon-wrap bg-info bg-opacity-10 text-info">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h5 class="fw-bold mb-2">@L["Home_SecureReliable"]</h5>
                <p class="text-muted small mb-0">@L["Home_SecureReliableDesc"]</p>
            </div>
        </div>
    </div>

    @* ─── FEATURED CARS ────────────────────────────── *@
    @if (Model.Any())
    {
        var gradients = new[] {
            "linear-gradient(135deg,#1e3a5f,#2563eb)",
            "linear-gradient(135deg,#3b1f6b,#7c3aed)",
            "linear-gradient(135deg,#134e4a,#0d9488)"
        };
        var idx = 0;
        <div class="mb-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <div class="section-eyebrow">@L["Home_FeaturedCars"]</div>
                    <h2 class="h3 fw-bold mb-0">@L["Home_TopPicks"]</h2>
                </div>
                <a asp-controller="Car" asp-action="Index" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                    @L["Home_ViewAll"] <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="row row-cols-1 row-cols-md-3 g-4">
                @foreach (var c in Model.Take(3))
                {
                    var grad = gradients[idx % gradients.Length];
                    idx++;
                    <div class="col">
                        <div class="card car-card h-100 border-0 shadow-sm">
                            @* Thumbnail *@
                            @if (!string.IsNullOrEmpty(c.ImageUrl))
                            {
                                <img src="@ImageHelper.Src(c.ImageUrl)" class="car-thumb" alt="@c.FullName">
                            }
                            else
                            {
                                <div class="car-thumb-placeholder" style="background: @grad;">
                                    <i class="bi bi-car-front-fill"></i>
                                </div>
                            }
                            @* Category badge *@
                            <div class="card-body p-3">
                                <span class="badge bg-primary bg-opacity-10 text-primary fw-semibold mb-2" style="font-size:0.7rem;">
                                    @c.Category.Name
                                </span>
                                <h5 class="card-title fw-bold mb-1" style="font-size:1rem;">@c.FullName</h5>
                                @if (!string.IsNullOrEmpty(c.Description))
                                {
                                    <p class="card-text text-muted mb-2" style="font-size:0.8rem; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">@c.Description</p>
                                }
                                @* Specs *@
                                <div class="d-flex flex-wrap gap-1 mb-3">
                                    <span class="car-spec-badge"><i class="bi bi-fuel-pump"></i> @c.FuelType</span>
                                    <span class="car-spec-badge"><i class="bi bi-gear"></i> @c.Transmission</span>
                                    <span class="car-spec-badge"><i class="bi bi-people"></i> @c.Seats</span>
                                </div>
                                @* Price + CTA *@
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="car-price">
                                        @c.PricePerDay.ToString("N0") ₴<span>@L["Car_PerDayShort"]</span>
                                    </div>
                                    <a asp-controller="Car" asp-action="Details" asp-route-id="@c.Id" class="btn-details">
                                        @L["Home_ViewDetails"]
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
